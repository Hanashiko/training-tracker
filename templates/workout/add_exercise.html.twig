{% extends "base.html.twig" %}

{% block title %}
    Add Exercise to Workout
{% endblock %}

{% block body %}
    <h1>Add Exercise to Workout {{ workout.date|date('d.m.Y') }}</h1>

    {{ form_start(form) }}
        {{ form_row(form.exercise) }}
        {{ form_row(form.sets) }}
        {{ form_row(form.reps) }}
        {{ form_row(form.weight) }}

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Add exercise</button>
            <a href="{{ path('app_workout_show', {'id': workout.id}) }}" class="btn btn-secondary">Cancel</a>
        </div>
    {{ form_end(form) }}

    <div class="mt-3">
        <a href="{{ path('app_exercise_new') }}" class="btn btn-success" target="_blank">
            Create new exercise
        </a>
    </div>
{% endblock %}
