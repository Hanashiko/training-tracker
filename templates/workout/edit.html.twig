{% extends "base.html.twig" %}

{% block title %}
    Edit Workout
{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>Edit Workout {{ workout.date|date('d.m.Y') }}</h1>

        {{ include('workout/_form.html.twig', {'button_label': 'Update'}) }}

        <div class="mt-3">
            <a href="{{ path('app_workout_index') }}" class="btn btn-secondary">
                Back to list
            </a>

            {{ include('workout/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
